{%- liquid
  assign text_position_1 = section.settings.text_position_1
  assign text_position_2 = section.settings.text_position_2
-%}

<div
  class="promo-banner section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="promo-banner__grid">

    {%- for i in (1..2) -%}
      {%- liquid
        assign image_key         = 'image_' | append: i
        assign subtitle_key      = 'subtitle_' | append: i
        assign title_key         = 'title_' | append: i
        assign button_text_key   = 'button_text_' | append: i
        assign button_url_key    = 'button_url_' | append: i
        assign text_position_key = 'text_position_' | append: i
        assign text_color_key    = 'text_color_' | append: i

        assign panel_image         = section.settings[image_key]
        assign panel_subtitle      = section.settings[subtitle_key]
        assign panel_title         = section.settings[title_key]
        assign panel_button_text   = section.settings[button_text_key]
        assign panel_button_url    = section.settings[button_url_key]
        assign panel_text_position = section.settings[text_position_key]
        assign panel_text_color    = section.settings[text_color_key]

        assign panel_class = 'promo-banner__panel promo-banner__panel--' | append: i
        if panel_text_position == 'top'
          assign panel_class = panel_class | append: ' promo-banner__panel--text-top'
        else
          assign panel_class = panel_class | append: ' promo-banner__panel--text-bottom'
        endif
      -%}

      <div class="{{ panel_class }}" style="--panel-text-color: {{ panel_text_color }};">

        {%- if panel_image != blank -%}
          {{
            panel_image
            | image_url: width: 1200
            | image_tag:
              class: 'promo-banner__image',
              loading: 'lazy',
              widths: '375, 550, 750, 1100',
              sizes: '(min-width: 750px) 66vw, 100vw'
          }}
        {%- else -%}
          <div class="promo-banner__image promo-banner__image--placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <div class="promo-banner__overlay"></div>

        <div class="promo-banner__content">
          <div class="promo-banner__text">
            {%- if panel_subtitle != blank -%}
              <p class="promo-banner__subtitle">{{ panel_subtitle }}</p>
            {%- endif -%}
            {%- if panel_title != blank -%}
              <h2 class="promo-banner__title">{{ panel_title }}</h2>
            {%- endif -%}
          </div>

          {%- if panel_button_text != blank -%}
            <a
              href="{{ panel_button_url | default: '#' }}"
              class="promo-banner__button"
            >
              {{ panel_button_text }}
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}
  /* ── Grid ── */
  .promo-banner__grid {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__grid {
      flex-direction: row;
      align-items: stretch;
    }
  }

  /* ── Panel sizing — matches Figma 580 : 1116 ratio ── */
  .promo-banner__panel--1 {
    flex: 580;
  }

  .promo-banner__panel--2 {
    flex: 1116;
  }

  /* ── Panel base ── */
  .promo-banner__panel {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    min-height: 420px;
    display: flex;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__panel {
      min-height: 660px;
    }
  }

  /* ── Background image ── */
  .promo-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .promo-banner__image--placeholder {
    background: #e8e8e8;
  }

  .promo-banner__image--placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Gradient overlay ── */
  .promo-banner__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Left panel: lighter gradient from bottom only */
  .promo-banner__panel--1 .promo-banner__overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 64%,
      rgba(0, 0, 0, 0.3) 116%
    );
  }

  /* Right panel: gradient starts earlier (40%) */
  .promo-banner__panel--2 .promo-banner__overlay {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0.45) 100%
    );
  }

  /* ── Content wrapper ── */
  .promo-banner__content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 32px 24px;
    gap: 10px;
    color: var(--panel-text-color, #ffffff);
  }

  /* Left panel: text top, button pushed to bottom */
  .promo-banner__panel--text-top .promo-banner__content {
    justify-content: space-between;
    align-items: center;
    text-align: center;
  }

  /* Right panel: everything at the bottom */
  .promo-banner__panel--text-bottom .promo-banner__content {
    justify-content: flex-end;
    align-items: center;
    text-align: center;
  }

  /* ── Text group ── */
  .promo-banner__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  /* ── Subtitle ── */
  .promo-banner__subtitle {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
    color: inherit;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__subtitle {
      font-size: 32px;
      line-height: 1.2;
    }
  }

  /* ── Title ── */
  .promo-banner__title {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 32px;
    line-height: 1.2;
    color: inherit;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__title {
      font-size: 48px;
      line-height: 1.2;
    }
  }

  /* ── Button ── */
  .promo-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 32px;
    background-color: #ffffff;
    color: #4a4a4a;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .promo-banner__button:hover {
    background-color: #4a4a4a;
    color: #ffffff;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full-width", "label": "Full width" },
        { "value": "page-width", "label": "Page width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Panel 1 (narrow — left)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle_1",
      "label": "Subtitle",
      "default": "Hurry up!"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title",
      "default": "Sale is Live"
    },
    {
      "type": "select",
      "id": "text_position_1",
      "label": "Text position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "top"
    },
    {
      "type": "color",
      "id": "text_color_1",
      "label": "Text color",
      "default": "#4a4a4a"
    },
    {
      "type": "text",
      "id": "button_text_1",
      "label": "Button label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_url_1",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Panel 2 (wide — right)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle_2",
      "label": "Subtitle",
      "default": "Winter Collection"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "New Arrival"
    },
    {
      "type": "select",
      "id": "text_position_2",
      "label": "Text position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "color",
      "id": "text_color_2",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Button label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
