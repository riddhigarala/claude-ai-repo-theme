<div
  class="promo-banner section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="promo-banner__grid">

    {%- for i in (1..2) -%}
      {%- liquid
        assign image_key        = 'image_' | append: i
        assign subtitle_key     = 'subtitle_' | append: i
        assign title_key        = 'title_' | append: i
        assign button_text_key  = 'button_text_' | append: i
        assign button_url_key   = 'button_url_' | append: i
        assign text_color_key   = 'text_color_' | append: i
        assign text_position_key = 'text_position_' | append: i
        assign panel_style_key  = 'panel_style_' | append: i
        assign bg_color_key     = 'panel_bg_color_' | append: i

        assign panel_image        = section.settings[image_key]
        assign panel_subtitle     = section.settings[subtitle_key]
        assign panel_title        = section.settings[title_key]
        assign panel_button_text  = section.settings[button_text_key]
        assign panel_button_url   = section.settings[button_url_key]
        assign panel_text_color   = section.settings[text_color_key]
        assign panel_text_pos     = section.settings[text_position_key]
        assign panel_style        = section.settings[panel_style_key]
        assign panel_bg_color     = section.settings[bg_color_key]
      -%}

      <div
        class="promo-banner__panel promo-banner__panel--{{ i }} promo-banner__panel--{{ panel_style }}"
        style="--panel-text-color: {{ panel_text_color }}; background-color: {{ panel_bg_color }};"
      >

        {%- if panel_image != blank -%}
          {{
            panel_image
            | image_url: width: 1200
            | image_tag:
              class: 'promo-banner__image',
              loading: 'lazy',
              widths: '375, 550, 750, 1100',
              sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="promo-banner__image promo-banner__image--placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if panel_style == 'full-bleed' -%}
          <div class="promo-banner__overlay promo-banner__overlay--full"></div>
        {%- else -%}
          <div class="promo-banner__overlay promo-banner__overlay--bottom"></div>
        {%- endif -%}

        {%- if panel_subtitle != blank or panel_title != blank -%}
          <div class="promo-banner__text-group promo-banner__text-group--{{ panel_text_pos }}">
            {%- if panel_subtitle != blank -%}
              <p class="promo-banner__subtitle">{{ panel_subtitle }}</p>
            {%- endif -%}
            {%- if panel_title != blank -%}
              <h2 class="promo-banner__title">{{ panel_title }}</h2>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if panel_button_text != blank -%}
          <div class="promo-banner__actions">
            <a href="{{ panel_button_url | default: '#' }}" class="promo-banner__button">
              {{ panel_button_text }}
            </a>
          </div>
        {%- endif -%}

      </div>
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}

  /* ── Grid ── */
  .promo-banner__grid {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__grid {
      flex-direction: row;
      align-items: stretch;
    }
  }

  /* ── Column widths — Figma ratio 580 : 1116 ── */
  .promo-banner__panel--1 { flex: 580; }
  .promo-banner__panel--2 { flex: 1116; }

  /* ── Panel base ── */
  .promo-banner__panel {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    min-height: 420px;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__panel {
      min-height: 660px;
    }
  }

  /* ── Background image ── */
  .promo-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .promo-banner__image--placeholder {
    background: #e8e8e8;
    position: absolute;
    inset: 0;
  }

  .promo-banner__image--placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
  }

  /* ── Overlays ── */
  .promo-banner__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* Left panel: subtle bottom-only gradient so button stays readable */
  .promo-banner__overlay--bottom {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 60%,
      rgba(0, 0, 0, 0.18) 100%
    );
  }

  /* Right panel: full dark gradient from 40% */
  .promo-banner__overlay--full {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0.45) 100%
    );
  }

  /* ── Text group — absolutely positioned ── */
  .promo-banner__text-group {
    position: absolute;
    left: 24px;
    right: 24px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    color: var(--panel-text-color, #ffffff);
  }

  /* Text at top */
  .promo-banner__text-group--top {
    top: 32px;
  }

  /* Text at bottom — sits above the button (button ~56px + 32px gap + 16px spacing = ~104px) */
  .promo-banner__text-group--bottom {
    bottom: 110px;
  }

  /* ── Subtitle ── */
  .promo-banner__subtitle {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
    color: inherit;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__subtitle {
      font-size: 32px;
    }
  }

  /* ── Title ── */
  .promo-banner__title {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 32px;
    line-height: 1.2;
    text-transform: uppercase;
    color: inherit;
  }

  @media screen and (min-width: 750px) {
    .promo-banner__title {
      font-size: 48px;
    }
  }

  /* ── Button row — absolutely at bottom ── */
  .promo-banner__actions {
    position: absolute;
    bottom: 32px;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    justify-content: center;
  }

  .promo-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 32px;
    background-color: #ffffff;
    color: #4a4a4a;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .promo-banner__button:hover {
    background-color: #4a4a4a;
    color: #ffffff;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full-width", "label": "Full width" },
        { "value": "page-width", "label": "Page width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Panel 1 — Left (narrow)"
    },
    {
      "type": "select",
      "id": "panel_style_1",
      "label": "Image style",
      "info": "Portrait: light background, text on top. Full-bleed: dark overlay, text over image.",
      "options": [
        { "value": "portrait", "label": "Portrait (light)" },
        { "value": "full-bleed", "label": "Full-bleed (dark overlay)" }
      ],
      "default": "portrait"
    },
    {
      "type": "color",
      "id": "panel_bg_color_1",
      "label": "Panel background color",
      "default": "#f2ede8"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle_1",
      "label": "Subtitle",
      "default": "Hurry up!"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title",
      "default": "Sale is Live"
    },
    {
      "type": "select",
      "id": "text_position_1",
      "label": "Text position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "top"
    },
    {
      "type": "color",
      "id": "text_color_1",
      "label": "Text color",
      "default": "#4a4a4a"
    },
    {
      "type": "text",
      "id": "button_text_1",
      "label": "Button label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_url_1",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Panel 2 — Right (wide)"
    },
    {
      "type": "select",
      "id": "panel_style_2",
      "label": "Image style",
      "options": [
        { "value": "portrait", "label": "Portrait (light)" },
        { "value": "full-bleed", "label": "Full-bleed (dark overlay)" }
      ],
      "default": "full-bleed"
    },
    {
      "type": "color",
      "id": "panel_bg_color_2",
      "label": "Panel background color",
      "default": "#1a1a1a"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle_2",
      "label": "Subtitle",
      "default": "Winter Collection"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "New Arrival"
    },
    {
      "type": "select",
      "id": "text_position_2",
      "label": "Text position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "color",
      "id": "text_color_2",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Button label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
